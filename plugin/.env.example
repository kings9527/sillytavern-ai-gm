# AI-GM Extension Environment Configuration
# Copy to .env for local backend development (not required for ST Extension)

# LLM Provider Configuration
AI_GM_LLM_PROVIDER=openai
AI_GM_LLM_BASE_URL=https://api.openai.com/v1
AI_GM_LLM_API_KEY=your_api_key_here
AI_GM_LLM_MODEL=gpt-4o-mini
AI_GM_LLM_MAX_TOKENS=512
AI_GM_LLM_TEMPERATURE=0.7
AI_GM_LLM_TIMEOUT=30000
AI_GM_LLM_RETRIES=2

# Mock Mode (no external LLM calls during testing)
AI_GM_MOCK_MODE=true

# Logging
LOG_LEVEL=info
