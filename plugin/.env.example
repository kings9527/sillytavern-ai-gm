# AI-GM Plugin Environment Configuration
# Copy to .env and fill in values

# Server Configuration
PORT=3000
NODE_ENV=development

# AI-GM Configuration
AI_GM_DEBUG=false
AI_GM_DEFAULT_SYSTEM=coc

# LLM Provider Configuration (AI-GM Phase 2)
# Provider: openai | claude | ollama | sillytavern
AI_GM_LLM_PROVIDER=openai
AI_GM_LLM_BASE_URL=https://api.openai.com/v1
AI_GM_LLM_API_KEY=your_api_key_here
AI_GM_LLM_MODEL=gpt-4o-mini
AI_GM_LLM_MAX_TOKENS=512
AI_GM_LLM_TEMPERATURE=0.7
AI_GM_LLM_TIMEOUT=30000
AI_GM_LLM_RETRIES=2

# SillyTavern Integration
SILLYTAVERN_URL=http://localhost:8000
SILLYTAVERN_API_KEY=

# Mock Mode (no external LLM calls)
AI_GM_MOCK_MODE=true

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/ai-gm.log

# Database (Phase 2: SQLite)
# DATABASE_PATH=./data/campaigns.db
