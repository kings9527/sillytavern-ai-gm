{
  "name": "sillytavern-ai-gm-extension",
  "version": "0.1.0",
  "description": "AI-GM Extension for SillyTavern — Cthulhu-style solo TRPG experience with LLM-driven storytelling, state panel, NPC decision, scene rendering, and dice resolution system.",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "node test/index.js && node test/extension-mount.js && node test/ui-integration.js && node test/campaign-storage.test.js && node test/npc-decision-advanced.test.js && node test/extension-lifecycle.test.js",
    "test:engine": "node test/index.js",
    "test:extension": "node test/extension-mount.js && node test/extension-lifecycle.test.js",
    "test:ui": "node test/ui-integration.js",
    "test:campaign": "node test/campaign-storage.test.js",
    "test:all": "node test/run-all.js",
    "test:coverage": "c8 --reporter=text --reporter=html --reporter=json-summary node test/run-all.js",
    "test:npc": "node test/npc-decision-advanced.test.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.js\" \"**/*.css\" \"**/*.json\" \"**/*.md\" --no-error-on-unmatched-pattern",
    "format:check": "prettier --check \"**/*.js\" \"**/*.css\" \"**/*.json\" \"**/*.md\" --no-error-on-unmatched-pattern",
    "check": "node --check index.js && node --check server.js && node --check engine/*.js && node --check utils/*.js && node --check storage/*.js && node --check ui/*.js",
    "dev:backend": "node --watch server.js",
    "dev:mock": "MOCK_MODE=true node --watch server.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1"
  },
  "keywords": [
    "sillytavern",
    "extension",
    "ttrpg",
    "ai",
    "gm"
  ],
  "license": "AGPL-3.0",
  "author": "kings9527",
  "c8": {
    "all": true,
    "include": [
      "utils/**/*.js",
      "engine/**/*.js",
      "storage/**/*.js"
    ],
    "exclude": [
      "test/**",
      "node_modules/**",
      "ui/**",
      "contracts/**",
      "index.js",
      "server.js"
    ],
    "reporter": [
      "text",
      "html",
      "json-summary"
    ],
    "lines": 80,
    "functions": 80,
    "branches": 70,
    "statements": 80
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "c8": "^11.0.0",
    "eslint": "^10.4.1",
    "globals": "^15.0.0",
    "prettier": "^3.8.3"
  }
}
