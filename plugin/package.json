{
  "name": "sillytavern-ai-gm-plugin",
  "version": "0.1.0",
  "description": "AI-GM backend plugin for SillyTavern",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "node test/index.js",
    "test:dice": "node test/index.js --grep Dice",
    "test:rules": "node test/index.js --grep Rule",
    "test:combat": "node test/index.js --grep Combat",
    "test:state": "node test/index.js --grep State",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write \"**/*.js\" \"**/*.css\" \"**/*.json\" \"**/*.md\"",
    "format:check": "prettier --check \"**/*.js\" \"**/*.css\" \"**/*.json\" \"**/*.md\"",
    "check": "node --check index.js && node --check engine/*.js && node --check utils/*.js && node --check storage/*.js",
    "dev": "node --watch index.js",
    "dev:mock": "MOCK_MODE=true node --watch index.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0"
  },
  "keywords": [
    "sillytavern",
    "plugin",
    "ttrpg",
    "ai",
    "gm"
  ],
  "license": "AGPL-3.0",
  "author": "kings9527",
  "devDependencies": {
    "eslint": "^10.4.1",
    "prettier": "^3.8.3"
  }
}
